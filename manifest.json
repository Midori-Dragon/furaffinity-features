{
    "manifest_version": 3,
    "name": "FurAffinity Features",
    "version": "1.3.14",
    "description": "A collection of features and enhancements for Fur Affinity",
    "author": "Midori Dragon",
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "*://*.furaffinity.net/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "*://*.furaffinity.net/*"
            ],
            "js": [
                "furaffinity-features.user.js"
            ],
            "run_at": "document_idle",
            "all_frames": true
        }
    ],
    "icons": {
        "16": "icons/icon-x16.png",
        "32": "icons/icon-x32.png",
        "48": "icons/icon-x48.png",
        "64": "icons/icon-x64.png",
        "96": "icons/icon-x96.png",
        "128": "icons/icon-x128.png"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "furaffinity-features@midori-dragon"
        }
    }
}