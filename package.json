{
  "name": "furaffinity-features",
  "version": "1.3.12",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "changed-modules": "node build-scripts/changed-modules.cjs --show-versions",
    "build:Browser-Extension": "node build-scripts/build-with-deps.cjs ./src/feature-modules/Furaffinity-Features-Browser/rollup.config.cjs --deps-from ./src/feature-modules/Furaffinity-Features/rollup.config.cjs && node build-scripts/copy-extension-resources.cjs",
    "build:Browser-Extension-Rebuild": "node build-scripts/build-with-deps.cjs ./src/feature-modules/Furaffinity-Features-Browser/rollup.config.cjs --deps-from ./src/feature-modules/Furaffinity-Features/rollup.config.cjs --rebuild && node build-scripts/copy-extension-resources.cjs",
    "build:Browser-Extension-Debug": "npm run lint && node build-scripts/build-with-deps.cjs ./src/feature-modules/Furaffinity-Features-Browser/rollup.config.cjs --deps-from ./src/feature-modules/Furaffinity-Features/rollup.config.cjs --debug && node build-scripts/copy-extension-resources.cjs",
    "build:Browser-Extension-Debug-Rebuild": "npm run lint && node build-scripts/build-with-deps.cjs ./src/feature-modules/Furaffinity-Features-Browser/rollup.config.cjs --deps-from ./src/feature-modules/Furaffinity-Features/rollup.config.cjs --debug --rebuild && node build-scripts/copy-extension-resources.cjs",
    "package:Browser-Extension": "node build-scripts/copy-extension-resources.cjs && node build-scripts/package-extension.cjs",
    "start:firefox": "web-ext run --source-dir=./dist",
    "start:chrome": "start chrome --load-extension=\"./dist\"",
    "serve": "http-server ./dist -p 8080 -c-1 -o -s",
    "docs": "docsify serve docs -o"
  },
  "keywords": [
    "userscript",
    "furry",
    "browser-extension",
    "enhancement",
    "features",
    "quality-of-life",
    "furaffinity",
    "furry-fandom"
  ],
  "author": "Midori Dragon",
  "license": "MIT",
  "description": "Collection of Features for Fur Affinity as UserScript or Browser Extension",
  "dependencies": {
    "@panzoom/panzoom": "^4.6.1",
    "pako": "^2.1.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/chrome": "^0.1.37",
    "@types/firefox-webext-browser": "^143.0.0",
    "@types/pako": "^2.0.4",
    "@types/webextension-polyfill": "^0.12.5",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "archiver": "^7.0.1",
    "docsify-cli": "^4.4.4",
    "eslint": "^9.0.0",
    "eslint-plugin-import": "^2.32.0",
    "http-server": "^14.1.1",
    "rollup": "^4.59.0",
    "rollup-plugin-postcss": "^4.0.2",
    "typescript": "^5.9.3",
    "web-ext": "^9.3.0"
  }
}